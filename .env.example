# ============================================================
# Awki Backend — Plantilla de variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env al repositorio
# ============================================================

# --- Base de datos (PostgreSQL) ---
DB_URL=jdbc:postgresql://<host>:5432/awki_db
DB_USERNAME=<usuario>
DB_PASSWORD=<contrasena>

# --- Redis ---
REDIS_HOST=<host>
REDIS_PORT=6379
REDIS_PASSWORD=<contrasena-o-dejar-vacio>

# --- JWT ---
# Generar con: openssl rand -base64 64
JWT_SECRET=<secreto-aleatorio-minimo-64-caracteres>
JWT_EXPIRATION=86400000

# --- Servidor ---
PORT=8080

# --- CORS ---
CORS_ALLOWED_ORIGINS=<url-del-frontend>

# --- Gemini AI (Google) ---
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<tu-api-key>

# --- Notificaciones ---
# true = respuestas simuladas sin llamar a la API real
GEMINI_MOCK_ENABLED=true

# En dev se puede dejar en true para usar mocks sin credenciales reales
NOTIFICATIONS_MOCK_ENABLED=true

# Twilio SMS — https://www.twilio.com/console
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=<ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx>
TWILIO_AUTH_TOKEN=<token>
TWILIO_FROM_NUMBER=<+1234567890>
TWILIO_TIMEOUT_SECONDS=10

# WhatsApp Business API — https://developers.facebook.com/docs/whatsapp
WHATSAPP_ENABLED=false
WHATSAPP_BUSINESS_TOKEN=<token>
WHATSAPP_PHONE_NUMBER_ID=<id>
WHATSAPP_TIMEOUT_SECONDS=10

# Firebase Cloud Messaging — https://console.firebase.google.com
FCM_ENABLED=false
FCM_CREDENTIALS_PATH=<ruta/al/serviceAccountKey.json>
FCM_TIMEOUT_SECONDS=10

# --- Almacenamiento de epicrisis ---
# Modos disponibles: local | s3
EPICRISIS_STORAGE_MODE=local
EPICRISIS_STORAGE_PATH=uploads/epicrisis
